{
  "name": "svc-photopoint-v1",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "nodemon --inspect src/server.ts",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "test": "cucumber-js",
    "test:unit": "jest --passWithNoTests",
    "test:unit:watch": "jest --watch --passWithNoTests",
    "test:unit:coverage": "jest --coverage --passWithNoTests",
    "test:blob": "cucumber-js src/tests/features/blobStorage.feature",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "azurite": "azurite --location ./ --debug azurite.log"
  },
  "keywords": [
    "photopoint",
    "api",
    "typescript",
    "express"
  ],
  "author": "",
  "license": "ISC",
  "description": "PhotoPoint API Service v1",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.28.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mssql": "^9.1.7",
    "@types/multer": "^2.0.0",
    "@types/passport": "^1.0.17",
    "@types/passport-facebook": "^3.0.3",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/sharp": "^0.31.1",
    "@types/uuid": "^10.0.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^4.18.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "mssql": "^11.0.1",
    "multer": "^2.0.2",
    "passport": "^0.7.0",
    "passport-apple": "^2.0.2",
    "passport-facebook": "^3.0.0",
    "passport-google-oauth20": "^2.0.0",
    "sharp": "^0.34.3",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.2.0",
    "@cucumber/pretty-formatter": "^2.1.0",
    "@types/chai": "^5.2.2",
    "@types/cors": "^2.8.19",
    "@types/jest": "^30.0.0",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.2.0",
    "chai": "^6.0.1",
    "concurrently": "^9.2.1",
    "jest": "^30.1.3",
    "nodemon": "^3.1.10",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  }
